rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check auth
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Users can read any user profile (for leaderboard), but only write to their own.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /userProgress/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /quizResults/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /onlineUsers/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; // Admin only in real app
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if false; // Admin only
    }

    match /videos/{videoId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin only in real app
    }

    match /communityPosts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /store_items/{itemId} {
      allow read: if true;
      allow write: if false; // Admin only
    }

    match /globalChat/{messageId} {
      allow read: if isAuthenticated();
      // Changed to expect userId and userName instead of uid and displayName
      allow create: if isAuthenticated() 
                    && request.resource.data.keys().hasAll(['userId', 'userName', 'text', 'timestamp'])
                    && request.resource.data.userId == request.auth.uid;
      // No edit or delete for now
      allow update, delete: if false;
      
      match /reactions/{reactionId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == reactionId;
      }
    }
    
    match /userCredentials/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
